# LLM API Configuration (supports any OpenAI SDK compatible LLM API)
# Recommended: Alibaba Bailian platform qwen-plus model: https://bailian.console.aliyun.com/
# Note: consumption can be high, try simulations with less than 40 rounds first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Zep Memory Graph Configuration =====
# Monthly free quota is sufficient for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM Configuration (Optional) =====
# Note: if not using boost config, do not include these entries in the env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Parity Swarm Research Configuration =====
# MiroFish backend URL (the simulation engine)
MIROFISH_URL=http://localhost:5001

# AWS Bedrock for Claude Haiku safety monitor
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307